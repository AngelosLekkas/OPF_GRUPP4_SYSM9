@using Microsoft.AspNetCore.Components.Authorization
@using CyberQuiz.Shared.DTOs
@using System.Security.Claims
@using CyberQuiz.UI.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject IQuizApiClient QuizApi
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center">

            <!--Visar olika beroende på vem som är inloggad eller om user ens är inloggad-->
            <AuthorizeView>
                <!--Om inloggad körs detta-->
                <Authorized Context="auth">

                    <span class="me-3">
                        👤 @auth.User.Identity?.Name
                    </span>
                
                    @if (progress != null)
                    {
                        <!--Visar hur många subcategories som är klarade av totalt antal subcategories-->
                        <span class="badge bg-success me-3">
                            @progress.CompletedSubCategories / @progress.TotalSubCategories
                        </span>
                    }
                </Authorized>

                <NotAuthorized>

                    <a href="/Account/Login" class="btn btn-outline-primary btn-sm me-2">
                        Login
                    </a>

                    <a href="/Account/Register" class="btn btn-outline-secondary btn-sm">
                        Register
                    </a>

                </NotAuthorized>
            </AuthorizeView>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {

    //Variabel som lagrar progressdata från API
    private UserProgressDto? progress;

    //när layout laddas
    protected override async Task OnInitializedAsync()
    {
        //använder blazor identity för authentisering
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        //user Id för unik progress overview
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId != null)
        {
            progress = await QuizApi.GetUserProgressAsync(userId);
        }
    }

}
